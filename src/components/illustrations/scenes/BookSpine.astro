---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 30 400" fill="none">
  <rect x="5" y="10" width="20" height="380" stroke="currentColor" stroke-width="1" fill="none" rx="2"/>
  <line x1="15" y1="30" x2="15" y2="370" stroke="currentColor" stroke-width="0.5" opacity="0.3"/>
  <!-- Decorative elements on spine -->
  <circle cx="15" cy="60" r="8" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="15" cy="60" r="3" fill="currentColor" opacity="0.2"/>
  <circle cx="15" cy="200" r="8" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="15" cy="200" r="3" fill="currentColor" opacity="0.2"/>
  <circle cx="15" cy="340" r="8" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="15" cy="340" r="3" fill="currentColor" opacity="0.2"/>
</svg>
