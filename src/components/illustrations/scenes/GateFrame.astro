---
// Static gate structure: posts, finials, arch, and climbing roses.
// Shares the 0 0 800 400 viewBox with GateDoorLeft/GateDoorRight so the
// layers stack pixel-perfectly when absolutely positioned over each other.
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 800 400"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Left gate post -->
  <rect x="50" y="80" width="30" height="320" stroke="currentColor" stroke-width="1.5" fill="none"
  ></rect>
  <circle cx="65" cy="100" r="8" stroke="currentColor" stroke-width="1" fill="none"></circle>
  <circle cx="65" cy="100" r="3" fill="currentColor" opacity="0.3"></circle>

  <!-- Right gate post -->
  <rect x="720" y="80" width="30" height="320" stroke="currentColor" stroke-width="1.5" fill="none"
  ></rect>
  <circle cx="735" cy="100" r="8" stroke="currentColor" stroke-width="1" fill="none"></circle>
  <circle cx="735" cy="100" r="3" fill="currentColor" opacity="0.3"></circle>

  <!-- Gate arch -->
  <path d="M80 80 Q400 -20 720 80" stroke="currentColor" stroke-width="1.5" fill="none"></path>
  <path d="M100 90 Q400 10 700 90" stroke="currentColor" stroke-width="1" fill="none" opacity="0.5"
  ></path>

  <!-- Climbing roses on the posts -->
  <g class="gate-roses">
    <!-- Left side roses -->
    <circle cx="100" cy="150" r="10" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
    <circle cx="100" cy="150" r="5" stroke="currentColor" stroke-width="0.5" fill="none"></circle>
    <circle cx="100" cy="150" r="2" fill="currentColor" opacity="0.3"></circle>
    <path d="M95 165 Q85 180 90 200" stroke="currentColor" stroke-width="0.6" fill="none"></path>

    <circle cx="85" cy="250" r="8" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
    <circle cx="85" cy="250" r="3" fill="currentColor" opacity="0.3"></circle>

    <!-- Right side roses -->
    <circle cx="700" cy="150" r="10" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
    <circle cx="700" cy="150" r="5" stroke="currentColor" stroke-width="0.5" fill="none"></circle>
    <circle cx="700" cy="150" r="2" fill="currentColor" opacity="0.3"></circle>
    <path d="M705 165 Q715 180 710 200" stroke="currentColor" stroke-width="0.6" fill="none"></path>

    <circle cx="715" cy="250" r="8" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
    <circle cx="715" cy="250" r="3" fill="currentColor" opacity="0.3"></circle>

    <!-- Leaves -->
    <path
      d="M80 180 Q70 175 68 185 Q75 188 80 180"
      stroke="currentColor"
      stroke-width="0.6"
      fill="none"></path>
    <path
      d="M720 180 Q730 175 732 185 Q725 188 720 180"
      stroke="currentColor"
      stroke-width="0.6"
      fill="none"></path>
  </g>
</svg>
