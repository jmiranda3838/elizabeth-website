---
// Left gate door (hinges on the left post). Drawn at its real coordinates
// inside the shared 0 0 800 400 viewBox so it aligns with GateFrame; the whole
// SVG element is swung open in CSS via transform-origin at the hinge edge.
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 800 400"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Translucent panel so the door reads as substance and softly catches the
       garden light; styled (fill) from garden-gate.css via .gate-door-panel. -->
  <rect class="gate-door-panel" x="90" y="100" width="290" height="300" rx="4"></rect>

  <rect x="90" y="100" width="290" height="300" stroke="currentColor" stroke-width="1" fill="none"
  ></rect>
  <!-- Vertical bars -->
  <line x1="150" y1="100" x2="150" y2="400" stroke="currentColor" stroke-width="0.8"></line>
  <line x1="210" y1="100" x2="210" y2="400" stroke="currentColor" stroke-width="0.8"></line>
  <line x1="270" y1="100" x2="270" y2="400" stroke="currentColor" stroke-width="0.8"></line>
  <line x1="330" y1="100" x2="330" y2="400" stroke="currentColor" stroke-width="0.8"></line>
  <!-- Horizontal rails -->
  <line x1="90" y1="200" x2="380" y2="200" stroke="currentColor" stroke-width="0.8"></line>
  <line x1="90" y1="300" x2="380" y2="300" stroke="currentColor" stroke-width="0.8"></line>
  <!-- Decorative scrollwork -->
  <path
    d="M120 150 Q150 130 180 150 Q210 170 180 190 Q150 210 120 190 Q90 170 120 150"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"></path>
  <path
    d="M280 150 Q310 130 340 150 Q370 170 340 190 Q310 210 280 190 Q250 170 280 150"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"></path>
</svg>
