---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M30 55 Q30 45 28 35 Q26 25 20 20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
  <path d="M28 40 Q20 38 15 42" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <ellipse cx="16" cy="16" rx="6" ry="8" stroke="currentColor" stroke-width="1" fill="none" transform="rotate(-30 16 16)"/>
  <ellipse cx="22" cy="12" rx="5" ry="7" stroke="currentColor" stroke-width="1" fill="none" transform="rotate(-10 22 12)"/>
  <ellipse cx="14" cy="22" rx="5" ry="6" stroke="currentColor" stroke-width="1" fill="none" transform="rotate(-50 14 22)"/>
  <circle cx="18" cy="18" r="3" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="18" cy="18" r="1" fill="currentColor" opacity="0.5"/>
</svg>
