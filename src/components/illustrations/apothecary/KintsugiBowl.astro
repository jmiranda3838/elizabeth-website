---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 60"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Bowl shape -->
  <path
    d="M12 28 Q12 45 30 48 Q48 45 48 28"
    stroke="currentColor"
    stroke-width="1.2"
    fill="none"
    stroke-linecap="round"></path>
  <ellipse cx="30" cy="28" rx="18" ry="6" stroke="currentColor" stroke-width="1" fill="none"
  ></ellipse>
  <!-- Kintsugi gold repair lines -->
  <path
    d="M20 30 Q22 38 24 46"
    stroke="currentColor"
    stroke-width="1.5"
    fill="none"
    stroke-linecap="round"
    opacity="0.7"></path>
  <path
    d="M36 29 Q38 36 42 42"
    stroke="currentColor"
    stroke-width="1.5"
    fill="none"
    stroke-linecap="round"
    opacity="0.7"></path>
  <path
    d="M28 28 Q26 34 28 40"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"
    opacity="0.5"></path>
  <!-- Small gold dots at repair intersections -->
  <circle cx="24" cy="46" r="1.5" fill="currentColor" opacity="0.6"></circle>
  <circle cx="42" cy="42" r="1.5" fill="currentColor" opacity="0.6"></circle>
  <circle cx="20" cy="30" r="1" fill="currentColor" opacity="0.5"></circle>
</svg>
