---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 60"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Rainbow/spectrum arcs -->
  <path
    d="M10 42 Q30 8 50 42"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M14 42 Q30 14 46 42"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"
    opacity="0.8"></path>
  <path
    d="M18 42 Q30 20 42 42"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"
    opacity="0.6"></path>
  <path
    d="M22 42 Q30 26 38 42"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"
    opacity="0.4"></path>
  <!-- Small botanical leaves at base -->
  <path d="M26 48 Q22 52 18 50 Q22 48 26 48" stroke="currentColor" stroke-width="0.8" fill="none"
  ></path>
  <path d="M34 48 Q38 52 42 50 Q38 48 34 48" stroke="currentColor" stroke-width="0.8" fill="none"
  ></path>
  <!-- Center stem -->
  <path d="M30 42 L30 55" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"
  ></path>
  <circle cx="30" cy="42" r="2" fill="currentColor" opacity="0.4"></circle>
</svg>
