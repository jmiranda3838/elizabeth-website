---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 60"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <ellipse
    cx="30"
    cy="32"
    rx="18"
    ry="12"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    transform="rotate(-15 30 32)"></ellipse>
  <ellipse
    cx="30"
    cy="32"
    rx="18"
    ry="12"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    transform="rotate(15 30 32)"></ellipse>
  <ellipse
    cx="30"
    cy="32"
    rx="10"
    ry="6"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    transform="rotate(-15 30 32)"></ellipse>
  <ellipse
    cx="30"
    cy="32"
    rx="10"
    ry="6"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    transform="rotate(15 30 32)"></ellipse>
  <ellipse cx="30" cy="45" rx="3" ry="8" stroke="currentColor" stroke-width="1" fill="none"
  ></ellipse>
  <path
    d="M28 25 Q26 18 24 12"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M32 25 Q34 18 36 12"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <circle cx="24" cy="11" r="1.5" stroke="currentColor" stroke-width="0.5" fill="none"></circle>
  <circle cx="36" cy="11" r="1.5" stroke="currentColor" stroke-width="0.5" fill="none"></circle>
</svg>
