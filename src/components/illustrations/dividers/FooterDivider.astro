---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 400 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="xMidYMid meet"
>
  <path d="M0 20 Q80 20 120 20" stroke="currentColor" stroke-width="1" stroke-linecap="round"
  ></path>
  <path d="M400 20 Q320 20 280 20" stroke="currentColor" stroke-width="1" stroke-linecap="round"
  ></path>
  <!-- Left branch -->
  <path
    d="M120 20 Q140 15 150 20 Q160 25 170 20"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M130 20 Q125 12 120 15"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M145 17 Q140 10 135 13"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <circle cx="118" cy="15" r="2" stroke="currentColor" stroke-width="0.6" fill="none"></circle>
  <!-- Center flower -->
  <circle cx="200" cy="20" r="8" stroke="currentColor" stroke-width="1" fill="none"></circle>
  <circle cx="200" cy="20" r="4" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="200" cy="20" r="1.5" fill="currentColor" opacity="0.5"></circle>
  <ellipse cx="200" cy="10" rx="3" ry="5" stroke="currentColor" stroke-width="0.8" fill="none"
  ></ellipse>
  <ellipse cx="200" cy="30" rx="3" ry="5" stroke="currentColor" stroke-width="0.8" fill="none"
  ></ellipse>
  <ellipse cx="190" cy="20" rx="5" ry="3" stroke="currentColor" stroke-width="0.8" fill="none"
  ></ellipse>
  <ellipse cx="210" cy="20" rx="5" ry="3" stroke="currentColor" stroke-width="0.8" fill="none"
  ></ellipse>
  <!-- Right branch -->
  <path
    d="M280 20 Q260 15 250 20 Q240 25 230 20"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M270 20 Q275 12 280 15"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M255 17 Q260 10 265 13"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <circle cx="282" cy="15" r="2" stroke="currentColor" stroke-width="0.6" fill="none"></circle>
</svg>
