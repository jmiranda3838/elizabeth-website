---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 150 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M0 10 Q30 10 50 10" stroke="currentColor" stroke-width="0.8"/>
  <path d="M150 10 Q120 10 100 10" stroke="currentColor" stroke-width="0.8"/>
  <circle cx="75" cy="10" r="4" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="75" cy="10" r="1.5" fill="currentColor" opacity="0.4"/>
</svg>
