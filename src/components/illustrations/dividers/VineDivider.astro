---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 200 30" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M0 15 Q30 15 50 15 Q60 15 70 12 Q80 8 90 15 Q100 22 110 15 Q120 8 130 12 Q140 15 150 15 Q170 15 200 15" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M70 12 Q65 6 60 8" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <path d="M90 15 Q85 20 80 18" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <path d="M110 15 Q115 10 120 12" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <path d="M130 12 Q135 6 140 8" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <circle cx="100" cy="15" r="3" stroke="currentColor" stroke-width="0.8" fill="none"/>
</svg>
