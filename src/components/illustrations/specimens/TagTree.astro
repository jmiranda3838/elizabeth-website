---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 80"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Tree with branches -->
  <path
    d="M30 75 Q30 55 30 40"
    stroke="currentColor"
    stroke-width="1.2"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M30 40 Q18 30 10 22"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M30 40 Q42 30 50 22"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M30 40 Q30 28 30 18"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <circle cx="10" cy="18" r="5" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="30" cy="13" r="6" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="50" cy="18" r="5" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="10" cy="18" r="2" fill="currentColor" opacity="0.3"></circle>
  <circle cx="30" cy="13" r="2.5" fill="currentColor" opacity="0.3"></circle>
  <circle cx="50" cy="18" r="2" fill="currentColor" opacity="0.3"></circle>
</svg>
