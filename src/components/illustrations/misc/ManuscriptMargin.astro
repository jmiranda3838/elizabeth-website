---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 40 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M20 190 Q20 150 20 110 Q20 70 20 30" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round" stroke-dasharray="3 4"/>
  <circle cx="20" cy="25" r="4" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="20" cy="60" r="3" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="20" cy="100" r="4" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="20" cy="140" r="3" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="20" cy="180" r="4" stroke="currentColor" stroke-width="0.6" fill="none"/>
</svg>
