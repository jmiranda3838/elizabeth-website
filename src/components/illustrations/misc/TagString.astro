---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 30 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M15 0 Q10 15 15 25 Q20 35 15 40" stroke="currentColor" stroke-width="1" fill="none"
  ></path>
</svg>
