---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 40 56"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Left leg -->
  <path
    d="M14 2 Q11 2 10.5 5 L8 34 Q7.5 39 10 46 Q11.5 50 13.5 53 Q14.5 54.5 16 53.5 Q17.5 52.5 16.8 50.8 Q14 44 13.5 38 L15.5 8 Q15.7 4 14 2 Z"
    stroke="currentColor"
    stroke-width="1.3"
    fill="currentColor"
    fill-opacity="0.12"></path>
  <!-- Right leg -->
  <path
    d="M26 2 Q29 2 29.5 5 L32 34 Q32.5 39 30 46 Q28.5 50 26.5 53 Q25.5 54.5 24 53.5 Q22.5 52.5 23.2 50.8 Q26 44 26.5 38 L24.5 8 Q24.3 4 26 2 Z"
    stroke="currentColor"
    stroke-width="1.3"
    fill="currentColor"
    fill-opacity="0.12"></path>
  <!-- Spring coil -->
  <circle cx="20" cy="22" r="5" stroke="currentColor" stroke-width="1.3" fill="none"></circle>
  <circle
    cx="20"
    cy="22"
    r="2"
    stroke="currentColor"
    stroke-width="1"
    fill="currentColor"
    fill-opacity="0.3"></circle>
  <!-- Spring arm -->
  <path
    d="M20 27 Q20 31 17 33"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
</svg>
