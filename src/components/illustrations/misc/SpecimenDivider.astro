---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 200 30" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M0 15 Q40 15 60 15" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <path d="M200 15 Q160 15 140 15" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <!-- Pressed flower center -->
  <circle cx="100" cy="15" r="8" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="100" cy="7" rx="3" ry="5" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <ellipse cx="100" cy="23" rx="3" ry="5" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <ellipse cx="92" cy="15" rx="5" ry="3" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <ellipse cx="108" cy="15" rx="5" ry="3" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="100" cy="15" r="3" fill="currentColor" opacity="0.3"/>
</svg>
