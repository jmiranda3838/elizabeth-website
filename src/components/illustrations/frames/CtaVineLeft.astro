---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 80 200"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M70 200 Q65 150 60 100 Q55 50 60 10"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M60 160 Q40 150 25 160"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M60 120 Q45 110 30 120"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M60 80 Q50 70 35 80"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    stroke-linecap="round"></path>
  <circle cx="60" cy="10" r="6" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="25" cy="160" r="4" stroke="currentColor" stroke-width="0.6" fill="none"></circle>
  <circle cx="30" cy="120" r="3" stroke="currentColor" stroke-width="0.6" fill="none"></circle>
</svg>
