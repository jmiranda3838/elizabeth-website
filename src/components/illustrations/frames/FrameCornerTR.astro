---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 40 40" fill="none">
  <path d="M0 0 L20 0 Q40 0 40 20 L40 40" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M20 8 Q32 8 32 20" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.5"/>
  <circle cx="35" cy="35" r="3" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.4"/>
</svg>
