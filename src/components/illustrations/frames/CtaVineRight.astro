---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 80 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M10 200 Q15 150 20 100 Q25 50 20 10" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M20 160 Q40 150 55 160" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <path d="M20 120 Q35 110 50 120" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <path d="M20 80 Q30 70 45 80" stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round"/>
  <circle cx="20" cy="10" r="6" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="55" cy="160" r="4" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="50" cy="120" r="3" stroke="currentColor" stroke-width="0.6" fill="none"/>
</svg>
