  <path d="M80 0 L80 40 Q80 80 40 80 L0 80" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M80 20 L80 50 Q80 70 50 70 L20 70" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.5"/>
  <circle cx="72" cy="10" r="4" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="10" cy="72" r="4" stroke="currentColor" stroke-width="0.8" fill="none"/>
</svg>
