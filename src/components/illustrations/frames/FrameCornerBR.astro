---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg class={className} style={style} viewBox="0 0 40 40" fill="none">
  <path
    d="M0 40 L0 20 Q0 0 20 0"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    transform="rotate(180 20 20)"></path>
  <circle cx="5" cy="5" r="3" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.4"
  ></circle>
</svg>
