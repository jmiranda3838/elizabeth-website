---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 60"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <circle cx="30" cy="30" r="22" stroke="currentColor" stroke-width="1.2" fill="none"></circle>
  <circle cx="30" cy="30" r="18" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.4"
  ></circle>
  <circle cx="26" cy="24" r="3" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.3"
  ></circle>
  <circle cx="35" cy="32" r="4" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.2"
  ></circle>
  <circle cx="28" cy="38" r="2" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.25"
  ></circle>
</svg>
