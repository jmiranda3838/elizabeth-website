---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Compass/journey -->
  <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1" fill="none"></circle>
  <circle cx="20" cy="20" r="10" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.5"
  ></circle>
  <path
    d="M20 8 L22 18 L20 20 L18 18 Z"
    stroke="currentColor"
    stroke-width="0.8"
    fill="currentColor"
    opacity="0.3"></path>
  <path d="M20 32 L18 22 L20 20 L22 22 Z" stroke="currentColor" stroke-width="0.8" fill="none"
  ></path>
  <circle cx="20" cy="20" r="2" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
</svg>
