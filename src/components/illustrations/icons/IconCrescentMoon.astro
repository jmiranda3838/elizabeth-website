---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M22 16c0-6-4.5-10-10-10 1 2 1.5 4.5 1.5 7s-0.5 5-1.5 7c5.5 0 10-4 10-10z"
    stroke="currentColor"
    stroke-width="1.2"
    fill="none"></path>
  <circle cx="18" cy="8" r="0.5" fill="currentColor" opacity="0.4"></circle>
  <circle cx="22" cy="14" r="0.5" fill="currentColor" opacity="0.3"></circle>
  <circle cx="20" cy="20" r="0.5" fill="currentColor" opacity="0.4"></circle>
</svg>
