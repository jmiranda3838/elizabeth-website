---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Crown/expertise -->
  <path
    d="M8 28 L12 15 L20 22 L28 15 L32 28"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linejoin="round"></path>
  <path d="M8 28 L32 28" stroke="currentColor" stroke-width="1"></path>
  <circle cx="12" cy="13" r="2" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="20" cy="10" r="2.5" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
  <circle cx="28" cy="13" r="2" stroke="currentColor" stroke-width="0.8" fill="none"></circle>
</svg>
