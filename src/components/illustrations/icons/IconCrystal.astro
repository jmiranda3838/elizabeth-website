    fill="none"
    stroke-linejoin="round"></path>
  <path d="M16 4 L16 28" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.4"></path>
  <path d="M10 10 L22 10" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.3"></path>
  <path d="M10 22 L22 22" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.3"></path>
  <path d="M13 7 L13 15" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.3"></path>
</svg>
