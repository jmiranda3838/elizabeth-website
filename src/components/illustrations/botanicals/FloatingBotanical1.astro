---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style = "" } = Astro.props;
---

<svg
  class={className}
  style={style}
  viewBox="0 0 60 80"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M30 75 Q28 50 30 25"
    stroke="currentColor"
    stroke-width="1"
    fill="none"
    stroke-linecap="round"></path>
  <ellipse cx="30" cy="20" rx="8" ry="12" stroke="currentColor" stroke-width="0.8" fill="none"
  ></ellipse>
  <ellipse
    cx="22"
    cy="28"
    rx="6"
    ry="10"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    transform="rotate(-25 22 28)"></ellipse>
  <ellipse
    cx="38"
    cy="28"
    rx="6"
    ry="10"
    stroke="currentColor"
    stroke-width="0.8"
    fill="none"
    transform="rotate(25 38 28)"></ellipse>
  <circle cx="30" cy="22" r="3" fill="currentColor" opacity="0.3"></circle>
</svg>
