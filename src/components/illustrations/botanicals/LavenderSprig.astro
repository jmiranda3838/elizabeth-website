---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 100 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M50 200 Q48 140 50 80" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
  <ellipse cx="50" cy="70" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="44" cy="60" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="56" cy="60" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="50" cy="50" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="44" cy="40" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="56" cy="40" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="50" cy="30" rx="4" ry="6" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="50" cy="20" rx="3" ry="5" stroke="currentColor" stroke-width="1" fill="none"/>
</svg>
