---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Vine wrapping around letter -->
  <path d="M10 100 Q5 70 15 50 Q25 30 20 10" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M15 85 Q5 80 3 88" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <path d="M18 60 Q8 55 6 63" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <path d="M20 35 Q30 30 32 38" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="3" cy="90" r="3" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="5" cy="65" r="2" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <circle cx="33" cy="40" r="2" stroke="currentColor" stroke-width="0.6" fill="none"/>
  <!-- Small flower at top -->
  <circle cx="20" cy="8" r="5" stroke="currentColor" stroke-width="0.8" fill="none"/>
  <circle cx="20" cy="8" r="2" fill="currentColor" opacity="0.3"/>
</svg>
