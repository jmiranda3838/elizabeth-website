---
interface Props {
  class?: string;
  style?: string;
}
const { class: className = '', style = '' } = Astro.props;
---
<svg class={className} style={style} viewBox="0 0 60 90" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- stem, pressed flat with a gentle bend -->
  <path d="M30 88 Q28 64 30 44 Q31 36 30 30" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
  <!-- two leaves, splayed as if pressed -->
  <path d="M30 66 Q18 60 12 64 Q18 70 30 66" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.12" stroke-linecap="round"/>
  <path d="M30 54 Q42 48 48 52 Q42 58 30 54" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.12" stroke-linecap="round"/>
  <!-- five splayed petals -->
  <ellipse cx="30" cy="13" rx="5" ry="11" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.16"/>
  <ellipse cx="18" cy="20" rx="5" ry="10" transform="rotate(-58 18 20)" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.16"/>
  <ellipse cx="42" cy="20" rx="5" ry="10" transform="rotate(58 42 20)" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.16"/>
  <ellipse cx="21" cy="31" rx="4.5" ry="9" transform="rotate(-115 21 31)" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.16"/>
  <ellipse cx="39" cy="31" rx="4.5" ry="9" transform="rotate(115 39 31)" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.16"/>
  <!-- flower centre -->
  <circle cx="30" cy="24" r="4" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.25"/>
</svg>
