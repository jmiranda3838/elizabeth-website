  <path d="M50 80 Q35 70 25 80 Q35 85 50 80" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M50 80 Q65 70 75 80 Q65 85 50 80" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
