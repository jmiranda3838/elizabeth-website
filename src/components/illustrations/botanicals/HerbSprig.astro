  <path d="M50 140 Q30 130 20 140 Q30 145 50 140" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M50 140 Q70 130 80 140 Q70 145 50 140" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
  <path d="M50 110 Q30 100 20 110 Q30 115 50 110" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/>
