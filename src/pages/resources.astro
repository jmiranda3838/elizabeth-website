---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resources | Elizabeth Armstrong Therapy" description="Mental health resources, recommended reading, and helpful articles from Elizabeth Armstrong, LMFT. Supporting your therapy journey.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Resources</p>
      <h1>Helpful Resources</h1>
      <p class="lead">
        A collection of articles, tools, and information to support your mental health journey.
      </p>
    </div>
  </section>

  <!-- Resources Content -->
  <section class="section bg-paper">
    <div class="container container-narrow">
      <h2 class="text-center">Coming Soon</h2>
      <div class="decorative-line center"></div>
      <p class="text-center">
        This page is currently being developed. Check back soon for helpful resources, recommended reading, and mental health tools.
      </p>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band">
    <div class="container">
      <h2>Ready to take the next step?</h2>
      <p>
        I offer a free 15-minute consultation where we can talk about what you're looking for and whether I might be the right therapist for you.
      </p>
      <a href="/contact.html" class="btn btn-primary btn-lg">Schedule Your Free Consultation</a>
    </div>
  </section>

</BaseLayout>
