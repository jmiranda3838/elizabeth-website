---
import BaseLayout from "../layouts/BaseLayout.astro";
import "@styles/pages/ways.css";
import { SpreadingTree } from "@illustrations/specimens";
import { IconHandsOpen, ArrowRight } from "@illustrations/icons";
import { WillowBranch } from "@illustrations/apothecary";
import { Wildflower } from "@illustrations/botanicals";
---

<BaseLayout
  title="Offerings | Elizabeth Armstrong Therapy"
  description="Therapy, Reiki, walk-and-talk sessions by the ocean, and an annual retreat — an honest map of the ways to work with Elizabeth Armstrong, LMFT, in Orange County."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Offerings</p>
      <h1>Ways we can work together</h1>
      <p class="lead">
        There are a few different ways into this work. Some are therapy and some aren't &mdash; and I'd rather tell you plainly which is which than blur the line. Here's the honest map.
      </p>
    </div>
  </section>

  <!-- The honest map -->
  <section class="section section-lg bg-paper">
    <div class="container">
      <div class="ways-grid">

        <article class="way-card reveal stagger-1">
          <span class="way-icon" aria-hidden="true"><SpreadingTree /></span>
          <h2>Therapy</h2>
          <p class="way-nature">Licensed psychotherapy</p>
          <p>Collaborative, kind talk therapy for individuals, couples, and families &mdash; narrative-based, strengths-focused, and unhurried. This is the heart of my practice.</p>
          <a href="/therapy.html" class="way-link">
            Explore therapy
            <ArrowRight />
          </a>
        </article>

        <article class="way-card reveal stagger-2">
          <span class="way-icon" aria-hidden="true"><IconHandsOpen /></span>
          <h2>Reiki</h2>
          <p class="way-nature">Energy work &mdash; not therapy</p>
          <p>A gentle, hands-light hour to rest and let your own system settle. Its own kind of session, with its own fee &mdash; never billed to insurance, never a substitute for medical or psychological care.</p>
          <a href="/reiki.html" class="way-link">
            Learn about Reiki
            <ArrowRight />
          </a>
        </article>

        <article class="way-card way-card--soon reveal stagger-3">
          <span class="way-icon" aria-hidden="true"><WillowBranch /></span>
          <h2>Walk-and-Talk</h2>
          <p class="way-nature">Talk therapy, outdoors</p>
          <p>The same therapy work, just on foot by the ocean &mdash; because we sit so much, and sometimes movement and fresh air are exactly what the conversation needs.</p>
          <span class="way-soon-chip">Coming soon &mdash; ask me</span>
        </article>

        <article class="way-card way-card--soon reveal stagger-4">
          <span class="way-icon" aria-hidden="true"><Wildflower /></span>
          <h2>Retreats</h2>
          <p class="way-nature">A small annual gathering</p>
          <p>Once a year, a few days to step away, rest, and renew in good company. A chance to breathe. Intimate by design.</p>
          <span class="way-soon-chip">Coming soon &mdash; ask me</span>
        </article>

      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band">
    <div class="container">
      <h2>Not sure which one fits?</h2>
      <p>
        That's completely normal &mdash; the free 15-minute consultation is the easiest way to figure it out, together. No pressure either way.
      </p>
      <a href="/contact.html" class="btn btn-primary btn-lg">Schedule Your Free Consultation</a>
    </div>
  </section>

</BaseLayout>
