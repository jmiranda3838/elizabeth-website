---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FloatingBotanical1, FloatingBotanical2, InitialFlourish, WelcomeWreath, PageBotanical } from "@illustrations/botanicals";
import { DoorwayFrame, BookSpine, RootsSystem, GardenGate } from "@illustrations/scenes";
import { ManuscriptCornerTL, ManuscriptCornerTR, ManuscriptCornerBL, ManuscriptCornerBR } from "@illustrations/frames";
import { PageDivider } from "@illustrations/dividers";
import { IconShield, IconHeart, IconCrown, IconSeedling, IconCompass } from "@illustrations/icons";
import { ConstellationStar, ManuscriptMargin, SpecimenDivider, TagString } from "@illustrations/misc";
import { TagBloomingFlower, TagIntertwinedStems, TagTree } from "@illustrations/specimens";
---

<BaseLayout title="Why Therapy | Elizabeth Armstrong Therapy" description="Therapy is for everyone. Discover a warm, non-judgmental space where you are the expert on your own life. Narrative therapy in Orange County and online across California.">

  <!-- Hero: The Threshold/Doorway -->
  <section class="threshold-hero">
    <!-- Atmospheric mist at bottom -->
    <div class="threshold-mist"></div>

    <!-- Candlelight glow effects -->
    <div class="candle-glow candle-glow-1"></div>
    <div class="candle-glow candle-glow-2"></div>

    <!-- The Arched Doorway Frame -->
    <div class="threshold-doorway">
      <DoorwayFrame class="doorway-frame" />

      <!-- Content within the doorway -->
      <div class="threshold-content">
        <p class="threshold-eyebrow">Step Inside</p>
        <h1 class="threshold-title">A Safe Space Awaits</h1>
        <p class="threshold-subtitle">Where healing begins and stories transform</p>
      </div>
    </div>

    <!-- Floating botanical elements -->
    <div class="floating-botanical floating-botanical-1">
      <FloatingBotanical1 />
    </div>
    <div class="floating-botanical floating-botanical-2">
      <FloatingBotanical2 />
    </div>
  </section>

  <!-- Illuminated Manuscript Quote Section -->
  <section class="illuminated-section">
    <div class="illuminated-page">
      <!-- Decorative corner flourishes -->
      <ManuscriptCornerTL class="manuscript-corner manuscript-corner-tl" />
      <ManuscriptCornerTR class="manuscript-corner manuscript-corner-tr" />
      <ManuscriptCornerBL class="manuscript-corner manuscript-corner-bl" />
      <ManuscriptCornerBR class="manuscript-corner manuscript-corner-br" />

      <div class="illuminated-content">
        <!-- Decorative initial letter -->
        <div class="illuminated-initial">
          <span class="initial-letter">D</span>
          <InitialFlourish class="initial-flourish" />
        </div>

        <blockquote class="illuminated-quote">
          <p><span class="quote-hidden-initial">D</span>on't surrender all your joy for an idea you used to have about yourself that isn't true anymore.</p>
          <footer class="quote-attribution">
            <span class="attribution-dash">—</span>
            <cite>Cheryl Strayed</cite>
          </footer>
        </blockquote>
      </div>

      <!-- Decorative botanical margin illustration -->
      <div class="manuscript-margin">
        <ManuscriptMargin />
      </div>
    </div>
  </section>

  <!-- Therapy Is For Everyone - Warm Welcome Section -->
  <section class="welcome-section">
    <div class="container">
      <div class="welcome-header">
        <div class="welcome-wreath">
          <WelcomeWreath />
        </div>
        <h2 class="welcome-title">Therapy Is For Everyone</h2>
        <p class="welcome-lead">We all have concerns, questions, and troubles—difficult or confusing times. As your therapist, I provide a safe space for us to explore solutions to life's challenges... together.</p>
      </div>

      <div class="welcome-content">
        <p class="welcome-intro">In my practice, you will be received with warmth, kindness, and genuine concern. I view problems as separate from people—whatever the issue may be, I strive to understand it through your lens.</p>

        <p class="welcome-emphasis">Using strengths-based, narrative, and mindfulness methods, we will explore your skills, abilities, ideals, and beliefs so you have a rich understanding of what is meaningful to you.</p>
      </div>
    </div>
  </section>

  <!-- The Grimoire: Sacred Promises Section -->
  <section class="grimoire-section">
    <div class="grimoire-book">
      <!-- Book spine decoration -->
      <div class="book-spine">
        <BookSpine />
      </div>

      <div class="grimoire-pages">
        <div class="grimoire-page grimoire-page-left">
          <div class="page-header">
            <span class="page-script">Sacred Promises</span>
            <div class="page-divider">
              <PageDivider />
            </div>
          </div>

          <div class="promise-list">
            <!-- Promise 1 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconShield />
              </div>
              <div class="promise-content">
                <h4>No Judgment</h4>
                <p>I will NOT judge you. This is a sanctuary free from criticism.</p>
              </div>
            </div>

            <!-- Promise 2 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconHeart />
              </div>
              <div class="promise-content">
                <h4>Unconditional Respect</h4>
                <p>I will RESPECT and HONOR your thoughts, feelings, opinions, and ideas unconditionally.</p>
              </div>
            </div>

            <!-- Promise 3 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconCrown />
              </div>
              <div class="promise-content">
                <h4>You Are The Expert</h4>
                <p>I will not tell you what to do. I believe you are the EXPERT on your own life.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grimoire-page grimoire-page-right">
          <div class="promise-list">
            <!-- Promise 4 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconSeedling />
              </div>
              <div class="promise-content">
                <h4>Facilitator of Growth</h4>
                <p>I will guide you as you explore what you VALUE—and how to approach your life in ways that reflect those values.</p>
              </div>
            </div>

            <!-- Promise 5 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconCompass />
              </div>
              <div class="promise-content">
                <h4>Your Journey</h4>
                <p>Therapy is all about YOU. I will be open, honest, genuine, and sincere—still, therapy is about YOUR journey.</p>
              </div>
            </div>
          </div>

          <!-- Decorative page element -->
          <div class="page-botanical">
            <PageBotanical />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Root System: Hidden Strength Section -->
  <section class="roots-section">
    <div class="container">
      <div class="roots-content">
        <div class="roots-text">
          <p class="roots-eyebrow">Your Hidden Strength</p>
          <h2 class="roots-title">No problem is bigger than your strength</h2>
          <p class="roots-description">Beneath every struggle lies a root system of resilience you may have forgotten. We will work collaboratively as I guide you—exploring what troubles you and how problems influence your life, decisions, and relationships.</p>
          <p class="roots-closing">I will support you as we work together to find relief from whatever weighs on you, so you may live a lighter, brighter, and more joyful life.</p>
        </div>

        <div class="roots-illustration">
          <RootsSystem class="roots-svg" />
        </div>
      </div>
    </div>
  </section>

  <!-- Constellation Map: What Therapy Addresses -->
  <section class="constellation-section">
    <div class="constellation-sky">
      <!-- Background stars -->
      <div class="star-field">
        <span class="tiny-star" style="top: 10%; left: 15%;"></span>
        <span class="tiny-star" style="top: 25%; left: 8%;"></span>
        <span class="tiny-star" style="top: 40%; left: 22%;"></span>
        <span class="tiny-star" style="top: 15%; left: 85%;"></span>
        <span class="tiny-star" style="top: 35%; left: 92%;"></span>
        <span class="tiny-star" style="top: 55%; left: 78%;"></span>
        <span class="tiny-star" style="top: 70%; left: 12%;"></span>
        <span class="tiny-star" style="top: 80%; left: 88%;"></span>
        <span class="tiny-star" style="top: 60%; left: 5%;"></span>
        <span class="tiny-star" style="top: 45%; left: 95%;"></span>
      </div>

      <div class="container">
        <div class="constellation-header">
          <p class="constellation-eyebrow">Navigate Your Journey</p>
          <h2 class="constellation-title">What brings people to therapy</h2>
          <p class="constellation-subtitle">Like stars in the night sky, each concern is connected to something deeper. Let's explore them together.</p>
        </div>

        <div class="constellation-map">
          <svg class="constellation-lines" viewBox="0 0 900 500">
            <!-- Lines generated dynamically by JavaScript -->
          </svg>

          <div class="constellation-stars">
            <!-- Star 1: Anxiety -->
            <div class="constellation-star" style="top: 15%; left: 15%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Anxiety</span>
            </div>

            <!-- Star 2: Depression -->
            <div class="constellation-star" style="top: 28%; left: 38%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Depression</span>
            </div>

            <!-- Star 3: Relationships -->
            <div class="constellation-star" style="top: 18%; left: 58%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Relationships</span>
            </div>

            <!-- Star 4: Grief -->
            <div class="constellation-star" style="top: 22%; left: 80%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Grief & Loss</span>
            </div>

            <!-- Star 5: Life Transitions -->
            <div class="constellation-star" style="top: 50%; left: 22%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Life Transitions</span>
            </div>

            <!-- Star 6: LGBTQ+ -->
            <div class="constellation-star" style="top: 65%; left: 42%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">LGBTQ+ Affirming</span>
            </div>

            <!-- Star 7: Career -->
            <div class="constellation-star" style="top: 58%; left: 63%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Career</span>
            </div>

            <!-- Star 8: Family -->
            <div class="constellation-star" style="top: 75%; left: 78%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Family & Couples</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Botanical Specimen Tags: Services Section -->
  <section class="specimen-tags-section">
    <div class="container">
      <div class="specimen-header">
        <h2>How I Can Help</h2>
        <div class="specimen-divider">
          <SpecimenDivider />
        </div>
      </div>

      <div class="specimen-tags-grid">
        <!-- Individual Therapy Tag -->
        <article class="specimen-tag">
          <div class="tag-hole"></div>
          <div class="tag-string">
            <TagString />
          </div>
          <div class="tag-content">
            <div class="tag-botanical">
              <TagBloomingFlower />
            </div>
            <h3 class="tag-title">Individual Therapy</h3>
            <p class="tag-latin">Solus florens</p>
            <p class="tag-description">A space for you to slow down and be heard. We'll untangle what feels stuck and rediscover what you value most.</p>
            <a href="#individual" class="tag-link">Learn more</a>
          </div>
        </article>

        <!-- Couples Therapy Tag -->
        <article class="specimen-tag">
          <div class="tag-hole"></div>
          <div class="tag-string">
            <TagString />
          </div>
          <div class="tag-content">
            <div class="tag-botanical">
              <TagIntertwinedStems />
            </div>
            <h3 class="tag-title">Couples Therapy</h3>
            <p class="tag-latin">Duorum nexus</p>
            <p class="tag-description">Reconnect with your partner in a space of safety. Explore your shared story and find new ways forward together.</p>
            <a href="#couples" class="tag-link">Learn more</a>
          </div>
        </article>

        <!-- Family Therapy Tag -->
        <article class="specimen-tag">
          <div class="tag-hole"></div>
          <div class="tag-string">
            <TagString />
          </div>
          <div class="tag-content">
            <div class="tag-botanical">
              <TagTree />
            </div>
            <h3 class="tag-title">Family Therapy</h3>
            <p class="tag-latin">Arbor familiae</p>
            <p class="tag-description">Strengthen the bonds that matter most. Understand patterns, improve communication, and grow together as a family.</p>
            <a href="#family" class="tag-link">Learn more</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Garden Gate: Final CTA -->
  <section class="garden-gate-section">
    <div class="gate-frame">
      <GardenGate class="gate-svg" />

      <div class="gate-content">
        <p class="gate-eyebrow">The Garden Awaits</p>
        <h2 class="gate-title">Ready to step through?</h2>
        <p class="gate-description">I offer a free 15-minute consultation to answer your questions and see if we're a good fit. There's no pressure—just a conversation about what you need.</p>
        <a href="/contact.html" class="btn btn-primary btn-lg gate-button">Open the Gate</a>
      </div>
    </div>
  </section>

<style is:global>
/* === Why Therapy Page - Magical Threshold Design === */

/* ============================================
   1. THRESHOLD HERO - The Doorway
   ============================================ */

.threshold-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(
    to bottom,
    var(--blush-wash) 0%,
    var(--warm-paper) 60%,
    rgba(210, 199, 193, 0.3) 100%
  );
  overflow: hidden;
  padding: calc(160px + var(--space-4)) var(--space-4) var(--space-20);
}

/* Atmospheric mist effect */
.threshold-mist {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200px;
  background: linear-gradient(
    to top,
    rgba(247, 246, 245, 0.95) 0%,
    rgba(247, 246, 245, 0.6) 40%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 2;
}

/* Candlelight glow effects */
.candle-glow {
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(249, 200, 194, 0.25) 0%,
    rgba(249, 200, 194, 0.1) 40%,
    transparent 70%
  );
  pointer-events: none;
  animation: candleFlicker 4s ease-in-out infinite;
}

.candle-glow-1 {
  top: 30%;
  left: 10%;
  animation-delay: 0s;
}

.candle-glow-2 {
  top: 25%;
  right: 10%;
  animation-delay: 2s;
}

@keyframes candleFlicker {
  0%, 100% {
    opacity: 0.6;
    transform: scale(1);
  }
  50% {
    opacity: 0.9;
    transform: scale(1.05);
  }
}

/* The Doorway Frame */
.threshold-doorway {
  position: relative;
  width: 100%;
  max-width: 500px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.doorway-frame {
  width: 100%;
  height: auto;
  color: var(--espresso);
}

.doorway-arch {
  stroke-dasharray: 2000;
  stroke-dashoffset: 2000;
  animation: drawArch 3s ease-out forwards;
}

@keyframes drawArch {
  to {
    stroke-dashoffset: 0;
  }
}

.doorway-vine {
  opacity: 0;
  animation: fadeInVine 1s ease-out forwards;
  animation-delay: 1.5s;
}

.doorway-vine-left {
  animation-delay: 1.8s;
}

.doorway-vine-right {
  animation-delay: 2s;
}

.doorway-crown {
  opacity: 0;
  animation: fadeInVine 1s ease-out forwards;
  animation-delay: 2.2s;
}

@keyframes fadeInVine {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Content within the doorway */
.threshold-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  padding: var(--space-8);
  width: 80%;
}

.threshold-eyebrow {
  font-family: var(--font-nav);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--sage);
  margin-bottom: var(--space-4);
  opacity: 0;
  animation: thresholdFadeInUp 0.8s ease-out forwards;
  animation-delay: 2.5s;
}

.threshold-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 400;
  color: var(--espresso);
  line-height: 1.2;
  margin-bottom: var(--space-4);
  opacity: 0;
  animation: thresholdFadeInUp 0.8s ease-out forwards;
  animation-delay: 2.7s;
}

.threshold-subtitle {
  font-family: var(--font-serif);
  font-size: var(--text-lg);
  font-style: italic;
  color: var(--slate-olive);
  opacity: 0;
  animation: thresholdFadeInUp 0.8s ease-out forwards;
  animation-delay: 2.9s;
}

@keyframes thresholdFadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Floating botanicals */
.floating-botanical {
  position: absolute;
  color: var(--dusty-peach);
  opacity: 0.4;
  animation: floatGentle 6s ease-in-out infinite;
}

.floating-botanical-1 {
  top: 15%;
  left: 5%;
  width: 60px;
  animation-delay: 0s;
}

.floating-botanical-2 {
  top: 20%;
  right: 8%;
  width: 50px;
  animation-delay: 3s;
}

@keyframes floatGentle {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-10px) rotate(3deg);
  }
}

/* ============================================
   2. ILLUMINATED MANUSCRIPT - Quote Section
   ============================================ */

.illuminated-section {
  background: var(--warm-paper);
  padding: var(--space-20) var(--space-4);
  display: flex;
  justify-content: center;
  align-items: center;
}

.illuminated-page {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
  padding: var(--space-16) var(--space-12);
  background: linear-gradient(
    135deg,
    rgba(253, 242, 239, 0.5) 0%,
    rgba(247, 246, 245, 0.8) 50%,
    rgba(253, 242, 239, 0.3) 100%
  );
  border: 1px solid var(--dusty-peach);
  box-shadow:
    0 4px 20px rgba(84, 49, 35, 0.08),
    inset 0 0 60px rgba(208, 180, 166, 0.1);
}

/* Corner flourishes */
.manuscript-corner {
  position: absolute;
  width: 80px;
  height: 80px;
  color: var(--dusty-peach);
}

.manuscript-corner-tl {
  top: 0;
  left: 0;
}

.manuscript-corner-tr {
  top: 0;
  right: 0;
}

.manuscript-corner-bl {
  bottom: 0;
  left: 0;
}

.manuscript-corner-br {
  bottom: 0;
  right: 0;
}

/* Content area */
.illuminated-content {
  display: flex;
  gap: var(--space-4);
  align-items: flex-start;
}

/* Decorative initial letter */
.illuminated-initial {
  position: relative;
  flex-shrink: 0;
}

.initial-letter {
  font-family: var(--font-serif);
  font-size: 5rem;
  font-weight: 600;
  line-height: 0.8;
  color: var(--espresso);
  display: block;
}

.initial-flourish {
  position: absolute;
  top: -10px;
  left: -20px;
  width: 100px;
  height: 120px;
  color: var(--sage);
  opacity: 0.6;
  z-index: -1;
}

/* Quote styling */
.illuminated-quote {
  flex: 1;
}

.illuminated-quote p {
  font-family: var(--font-serif);
  font-size: clamp(1.25rem, 3vw, 1.75rem);
  font-style: italic;
  line-height: 1.6;
  color: var(--espresso);
  margin: 0;
}

.quote-hidden-initial {
  visibility: hidden;
  font-size: 0;
}

.quote-attribution {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-6);
  font-style: normal;
}

.attribution-dash {
  color: var(--dusty-peach);
  font-size: var(--text-lg);
}

.quote-attribution cite {
  font-family: var(--font-nav);
  font-size: var(--text-sm);
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--sage);
}

/* Margin decoration */
.manuscript-margin {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 200px;
  color: var(--dusty-peach);
  opacity: 0.4;
}

/* ============================================
   3. WELCOME SECTION - Therapy Is For Everyone
   ============================================ */

.welcome-section {
  background: var(--blush-wash);
  padding: var(--space-20) var(--space-4);
}

.welcome-header {
  text-align: center;
  max-width: 700px;
  margin: 0 auto var(--space-12);
}

.welcome-wreath {
  width: 120px;
  height: 120px;
  margin: 0 auto var(--space-6);
  color: var(--sage);
}

.welcome-wreath svg {
  width: 100%;
  height: 100%;
}

.welcome-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 400;
  color: var(--espresso);
  margin-bottom: var(--space-6);
}

.welcome-lead {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  font-style: italic;
  line-height: 1.7;
  color: var(--slate-olive);
}

.welcome-content {
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
}

.welcome-intro,
.welcome-emphasis {
  font-size: var(--text-lg);
  line-height: 1.8;
  color: var(--text-primary);
  margin-bottom: var(--space-6);
}

.welcome-emphasis {
  color: var(--slate-olive);
}

/* ============================================
   4. GRIMOIRE SECTION - Sacred Promises
   ============================================ */

.grimoire-section {
  background: linear-gradient(
    to bottom,
    var(--soft-sand) 0%,
    var(--warm-paper) 100%
  );
  padding: var(--space-24) var(--space-4);
  display: flex;
  justify-content: center;
}

.grimoire-book {
  position: relative;
  display: flex;
  max-width: 1000px;
  width: 100%;
  background: var(--warm-paper);
  box-shadow:
    0 10px 40px rgba(84, 49, 35, 0.15),
    0 2px 10px rgba(84, 49, 35, 0.1);
  border-radius: 4px 12px 12px 4px;
}

/* Book spine */
.book-spine {
  width: 30px;
  background: linear-gradient(
    to right,
    var(--dusty-peach) 0%,
    var(--warm-clay) 50%,
    var(--dusty-peach) 100%
  );
  border-radius: 4px 0 0 4px;
  flex-shrink: 0;
}

.book-spine svg {
