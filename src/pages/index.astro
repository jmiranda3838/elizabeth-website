---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Wildflower, HerbSprig, LeafBranch, SeedPodCluster, LavenderSprig } from "@illustrations/botanicals";
import { Garland } from "@illustrations/scenes";
import { LeafDivider, VineDivider } from "@illustrations/dividers";
import { BloomingFlower, IntertwinedStems, SpreadingTree } from "@illustrations/specimens";
import { ArrowRight, IconCrescentMoon, IconStar, IconSun, IconCrystal } from "@illustrations/icons";
import { FrameCornerTL, FrameCornerTR, FrameCornerBL, FrameCornerBR, CtaVineLeft, CtaVineRight } from "@illustrations/frames";
import { Moth, DroopingFlower, Butterfly, TwoFlowers, KintsugiBowl, WillowBranch, SpectrumArc, Seedling } from "@illustrations/apothecary";
import { NewMoon, WaxingMoon, FullMoon } from "@illustrations/moon";
import { MoonPath, QuoteMark } from "@illustrations/misc";
---

<BaseLayout title="Elizabeth Armstrong Therapy | Narrative Therapist in Orange County, CA">
  <!-- Hero Section - Full Bleed Photo with Botanicals -->
  <section class="hero-botanical">
    <!-- Overlay for text readability -->
    <div class="hero-overlay"></div>

    <!-- Botanical Line Art Elements -->
    <Wildflower class="botanical botanical-1" />
    <HerbSprig class="botanical botanical-2" />
    <LeafBranch class="botanical botanical-3" />
    <SeedPodCluster class="botanical botanical-4" />
    <LavenderSprig class="botanical botanical-5" />

    <!-- Text Content -->
    <div class="hero-text-content">
      <h1 class="hero-tagline">Collaborative, kind therapy to promote growth and healing</h1>
      <p class="hero-name">Elizabeth Armstrong, LMFT</p>
    </div>
    <!-- Hanging Botanical Garland - extends past hero edge -->
    <div class="hero-garland">
      <Garland class="garland-svg" />
    </div>
  </section>

  <!-- Services Section - Botanical Specimen Cards -->
  <section class="section section-services bg-paper">
    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">How I Can Help</p>
        <h2>Therapy for Individuals, Couples & Families</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
        <p class="lead container-text mx-auto">
          Whether you're navigating life on your own, working through challenges with a partner, or seeking support for your family, I offer a collaborative space to explore what's possible.
        </p>
      </div>

      <div class="services-grid specimen-cards">
        <!-- Individual Therapy Card -->
        <article class="service-card specimen-card reveal stagger-1">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Single blooming flower -->
            <BloomingFlower class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Individual Therapy</h3>
            <p>A space to slow down, make sense of your experiences, and rediscover what you value most. We'll work together to untangle what feels stuck.</p>
            <a href="/therapy.html#individual" class="service-card-link">
              Learn more
              <ArrowRight />
            </a>
          </div>
        </article>

        <!-- Couples Therapy Card -->
        <article class="service-card specimen-card reveal stagger-2">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Two intertwined stems -->
            <IntertwinedStems class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Couples Therapy</h3>
            <p>Reconnect with your partner in a space of safety and respect. We'll explore the stories you've created together and find new ways forward.</p>
            <a href="/therapy.html#couples" class="service-card-link">
              Learn more
              <ArrowRight />
            </a>
          </div>
        </article>

        <!-- Family Therapy Card -->
        <article class="service-card specimen-card reveal stagger-3">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Tree with spreading branches -->
            <SpreadingTree class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Family Therapy</h3>
            <p>Strengthen the bonds that matter most. Family therapy helps you understand patterns, improve communication, and grow together.</p>
            <a href="/therapy.html#family" class="service-card-link">
              Learn more
              <ArrowRight />
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Beyond the Therapy Room: Reiki + future offerings -->
  <section class="beyond-band">
    <div class="container beyond-band-inner reveal">
      <span class="beyond-band-icon" aria-hidden="true">
        <IconSun />
      </span>
      <div class="beyond-band-text">
        <h2>Beyond the therapy room</h2>
        <p>
          Talk therapy is the heart of what I do &mdash; but it isn't the only door in. I now offer <a href="/reiki.html">Reiki</a> as its own quiet hour, with walk-and-talk sessions by the ocean and a small annual retreat on the way.
        </p>
      </div>
      <a href="/ways.html" class="btn btn-outline">See all offerings</a>
    </div>
  </section>

  <!-- Approach / Philosophy Section - The Grimoire -->
  <section class="section section-lg bg-blush approach-section grimoire-section">
    <div class="container">
      <div class="approach-content">
        <div class="approach-text reveal-left">
          <p class="eyebrow">My Approach</p>
          <h2>Narrative therapy starts with your story</h2>
          <!-- Decorative vine divider -->
          <div class="vine-divider">
            <VineDivider />
          </div>
          <p>
            I believe you are the expert on your own life. My role isn't to diagnose or fix, but to walk alongside you with curiosity and care. Narrative therapy helps us examine the stories you've been told, the ones you tell yourself, and the ones that haven't yet found voice.
          </p>
          <p>
            Together, we'll separate you from the problem, discover the values that guide you, and uncover the "sparkling moments" that point toward your preferred way of living.
          </p>

          <div class="values-list magical-values">
            <!-- Collaborative - Crescent Moon -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconCrescentMoon />
              </div>
              <div class="value-content">
                <h4>Collaborative</h4>
                <p>We work together as partners. You set the direction; I offer reflection and support.</p>
              </div>
            </div>

            <!-- Respectful - Star -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconStar />
              </div>
              <div class="value-content">
                <h4>Respectful & Non-Pathologizing</h4>
                <p>Problems are problems; you are not the problem. We work with struggles, not labels.</p>
              </div>
            </div>

            <!-- Culturally Aware - Sun -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconSun />
              </div>
              <div class="value-content">
                <h4>Culturally Aware</h4>
                <p>I honor the cultural, social, and personal contexts that shape your experience.</p>
              </div>
            </div>

            <!-- Practical - Crystal -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconCrystal />
              </div>
              <div class="value-content">
                <h4>Practical & Reflective</h4>
                <p>We balance deep reflection with real-world strategies you can use today.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Botanical framed image area -->
        <div class="approach-image botanical-frame reveal-right">
          <div class="botanical-frame-border">
            <FrameCornerTL class="frame-corner frame-tl" />
            <FrameCornerTR class="frame-corner frame-tr" />
            <FrameCornerBL class="frame-corner frame-bl" />
            <FrameCornerBR class="frame-corner frame-br" />
          </div>
          <img src="/images/headshot.jpg" alt="Elizabeth - Therapist headshot" class="approach-headshot">
        </div>
      </div>
    </div>
  </section>

  <!-- Areas of Support Section - Apothecary Cabinet -->
  <section class="section bg-paper apothecary-section">
    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">Areas of Support</p>
        <h2>What brings people to therapy</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
        <p class="lead container-text mx-auto">
          Life presents us with challenges that can feel overwhelming. Here are some of the themes I commonly work with, though your experience is always unique.
        </p>
      </div>

      <div class="apothecary-grid">
        <!-- Anxiety - Fluttering Moth -->
        <div class="apothecary-item reveal stagger-1">
          <div class="apothecary-icon">
            <Moth />
          </div>
          <h4>Anxiety</h4>
          <p>When worry becomes the loudest voice in the room</p>
        </div>

        <!-- Depression - Drooping Flower -->
        <div class="apothecary-item reveal stagger-2">
          <div class="apothecary-icon">
            <DroopingFlower />
          </div>
          <h4>Depression</h4>
          <p>When life feels heavy, gray, or far away</p>
        </div>

        <!-- Life Transitions - Butterfly Emerging -->
        <div class="apothecary-item reveal stagger-3">
          <div class="apothecary-icon">
            <Butterfly />
          </div>
          <h4>Life Transitions</h4>
          <p>Navigating change with clarity and intention</p>
        </div>

        <!-- Relationship Issues - Two Flowers Turned Away -->
        <div class="apothecary-item reveal stagger-4">
          <div class="apothecary-icon">
            <TwoFlowers />
          </div>
          <h4>Relationship Issues</h4>
          <p>Finding new patterns in how you connect</p>
        </div>

        <!-- Trauma - Kintsugi Bowl -->
        <div class="apothecary-item reveal stagger-5">
          <div class="apothecary-icon">
            <KintsugiBowl />
          </div>
          <h4>Trauma</h4>
          <p>When the past still echoes in the present</p>
        </div>

        <!-- Grief & Loss - Willow Branch -->
        <div class="apothecary-item reveal stagger-6">
          <div class="apothecary-icon">
            <WillowBranch />
          </div>
          <h4>Grief & Loss</h4>
          <p>Making space for what you've loved and lost</p>
        </div>

        <!-- LGBTQ+ - Spectrum Arc with Botanical -->
        <div class="apothecary-item reveal stagger-7">
          <div class="apothecary-icon">
            <SpectrumArc />
          </div>
          <h4>LGBTQ+</h4>
          <p>An affirming space for all identities and journeys</p>
        </div>

        <!-- Self-Esteem - Seedling Reaching Light -->
        <div class="apothecary-item reveal stagger-8">
          <div class="apothecary-icon">
            <Seedling />
          </div>
          <h4>Self-Esteem</h4>
          <p>Rediscovering the worth that was always there</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section - Moon Phases Journey -->
  <section class="section bg-sand moon-journey-section">
    <!-- Decorative botanical vine divider - top (CSS background pattern) -->
    <div class="vine-divider vine-divider-top"></div>

    <!-- Decorative botanical vine divider - bottom (CSS background pattern) -->
    <div class="vine-divider vine-divider-bottom"></div>

    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">How It Works</p>
        <h2>Starting therapy is simple</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
      </div>

      <div class="moon-steps-grid">
        <!-- Connecting vine path -->
        <div class="moon-path">
          <MoonPath />
        </div>

        <div class="moon-step reveal stagger-1">
          <!-- New Moon -->
          <div class="moon-icon">
            <NewMoon />
          </div>
          <h3>Free Consultation</h3>
          <p class="moon-phase-label">New Moon</p>
          <p>We'll have a brief call to discuss what brings you to therapy and answer any questions. This helps us both determine if we're a good fit.</p>
        </div>

        <div class="moon-step reveal stagger-2">
          <!-- Half Moon -->
          <div class="moon-icon">
            <WaxingMoon />
          </div>
          <h3>First Session</h3>
          <p class="moon-phase-label">Waxing Moon</p>
          <p>In our first meeting, we'll explore your story more deeply. I'll get to know you and what matters most. You'll get a sense of how we work together.</p>
        </div>

        <div class="moon-step reveal stagger-3">
          <!-- Full Moon -->
          <div class="moon-icon">
            <FullMoon />
          </div>
          <h3>Ongoing Work</h3>
          <p class="moon-phase-label">Full Moon</p>
          <p>We'll meet regularly (typically weekly) to continue our exploration. Each session builds on the last, moving at a pace that feels right for you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Clients Tell Me Section - Journal Pages -->
  <section class="section bg-paper testimonial-section journal-section">
    <div class="container">
      <div class="text-center mb-10">
        <p class="eyebrow">What Clients Often Tell Me</p>
        <h2>When people reach out, they often share thoughts like these...</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
      </div>

      <div class="journal-pages">
        <div class="journal-page reveal stagger-1" style="--rotation: -2deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to feel like myself again, but I'm not even sure who that is anymore.</p>
        </div>

        <div class="journal-page reveal stagger-2" style="--rotation: 1.5deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I know what I should do, but I can't seem to make it happen.</p>
        </div>

        <div class="journal-page reveal stagger-3" style="--rotation: -1deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to stop having the same argument over and over with my partner.</p>
        </div>

        <div class="journal-page reveal stagger-4" style="--rotation: 2deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I need a space where I don't have to perform or pretend everything is fine.</p>
        </div>

        <div class="journal-page reveal stagger-5" style="--rotation: -1.5deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to understand why I keep getting in my own way.</p>
        </div>
      </div>

      <p class="journal-closing">
        If any of these resonate, you're in the right place.
      </p>
    </div>
  </section>

  <!-- Final CTA Band - The Invitation -->
  <section class="cta-band botanical-cta">
    <!-- Botanical frame elements -->
    <div class="cta-botanical cta-botanical-left">
      <CtaVineLeft />
    </div>
    <div class="cta-botanical cta-botanical-right">
      <CtaVineRight />
    </div>

    <div class="container">
      <div class="cta-content reveal">
        <div class="decorative-divider mb-6">
          <LeafDivider />
        </div>
        <h2>Ready to take the first step?</h2>
        <p>
          I offer a free 15-minute consultation to see if we're a good fit. There's no pressure, just a conversation.
        </p>
        <a href="/contact.html" class="btn btn-primary btn-lg cta-button">Schedule Your Free Consultation</a>
      </div>
    </div>
  </section>
</BaseLayout>
