---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Wildflower, HerbSprig, LeafBranch, SeedPodCluster, LavenderSprig, InitialFlourish, PageBotanical } from "@illustrations/botanicals";
import { Garland, BookSpine, RootsSystem, GardenGate } from "@illustrations/scenes";
import { LeafDivider, VineDivider, PageDivider } from "@illustrations/dividers";
import { BloomingFlower, IntertwinedStems, SpreadingTree } from "@illustrations/specimens";
import { IconCrescentMoon, IconStar, IconSun, IconCrystal, IconShield, IconHeart, IconCrown, IconSeedling, IconCompass } from "@illustrations/icons";
import { FrameCornerTL, FrameCornerTR, FrameCornerBL, FrameCornerBR, ManuscriptCornerTL, ManuscriptCornerTR, ManuscriptCornerBL, ManuscriptCornerBR } from "@illustrations/frames";
import { Moth, DroopingFlower, Butterfly, TwoFlowers, KintsugiBowl, WillowBranch, SpectrumArc, Seedling } from "@illustrations/apothecary";
import { NewMoon, WaxingMoon, FullMoon } from "@illustrations/moon";
import { MoonPath, QuoteMark, ConstellationStar, ManuscriptMargin } from "@illustrations/misc";
---

<BaseLayout
  title="Elizabeth Armstrong Therapy | Narrative Therapist in Orange County, CA"
  description="Collaborative, kind narrative therapy for individuals, couples, and families — in Orange County and online across California. A warm, non-judgmental space where you are the expert on your own life."
>
  <!-- Hero Section - Full Bleed Photo with Botanicals -->
  <section class="hero-botanical">
    <!-- Overlay for text readability -->
    <div class="hero-overlay"></div>

    <!-- Botanical Line Art Elements -->
    <Wildflower class="botanical botanical-1" />
    <HerbSprig class="botanical botanical-2" />
    <LeafBranch class="botanical botanical-3" />
    <SeedPodCluster class="botanical botanical-4" />
    <LavenderSprig class="botanical botanical-5" />

    <!-- Text Content -->
    <div class="hero-text-content">
      <h1 class="hero-tagline">Collaborative, kind therapy to promote growth and healing</h1>
      <p class="hero-name">Elizabeth Armstrong, LMFT</p>
    </div>
    <!-- Hanging Botanical Garland - extends past hero edge -->
    <div class="hero-garland">
      <Garland class="garland-svg" />
    </div>
  </section>

  <!-- Services Section - Botanical Specimen Cards -->
  <section id="services" class="section section-services bg-paper">
    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">How I Can Help</p>
        <h2>Therapy for Individuals, Couples & Families</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
        <p class="lead container-text mx-auto">
          Whether you're navigating life on your own, working through challenges with a partner, or seeking support for your family, I offer a collaborative space to explore what's possible.
        </p>
      </div>

      <div class="services-grid specimen-cards">
        <!-- Individual Therapy Card -->
        <article id="individual" class="service-card specimen-card reveal stagger-1">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Single blooming flower -->
            <BloomingFlower class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Individual Therapy</h3>
            <p class="specimen-latin">Solus florens</p>
            <p>A space to slow down and be heard &mdash; to make sense of your experiences and rediscover what you value most. Together, we'll untangle what feels stuck.</p>
          </div>
        </article>

        <!-- Couples Therapy Card -->
        <article id="couples" class="service-card specimen-card reveal stagger-2">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Two intertwined stems -->
            <IntertwinedStems class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Couples Therapy</h3>
            <p class="specimen-latin">Duorum nexus</p>
            <p>Reconnect with your partner in a space of safety and respect. We'll explore the story you've created together and find new ways forward.</p>
          </div>
        </article>

        <!-- Family Therapy Card -->
        <article id="family" class="service-card specimen-card reveal stagger-3">
          <div class="specimen-corner specimen-corner-tl"></div>
          <div class="specimen-corner specimen-corner-tr"></div>
          <div class="specimen-corner specimen-corner-bl"></div>
          <div class="specimen-corner specimen-corner-br"></div>
          <div class="service-card-image">
            <!-- Tree with spreading branches -->
            <SpreadingTree class="specimen-icon" />
          </div>
          <div class="service-card-content">
            <h3>Family Therapy</h3>
            <p class="specimen-latin">Arbor familiae</p>
            <p>Strengthen the bonds that matter most. Family therapy helps you understand patterns, improve communication, and grow together.</p>
          </div>
        </article>
      </div>

      <!-- Walk-and-talk: same therapy, on foot by the ocean -->
      <p class="services-soon-note reveal">
        <span class="soon-badge">Coming soon</span>
        Walk-and-talk therapy &mdash; the same work we'd do in the office, just on foot
        along the ocean. We sit so much; sometimes movement and salt air are exactly
        what the conversation needs. If it calls to you, mention it when we talk.
      </p>
    </div>
  </section>

  <!-- Beyond the Therapy Room: Reiki -->
  <section class="beyond-band">
    <div class="container beyond-band-inner reveal">
      <span class="beyond-band-icon" aria-hidden="true">
        <IconSun />
      </span>
      <div class="beyond-band-text">
        <h2>Beyond the therapy room</h2>
        <p>
          Talk therapy is the heart of what I do &mdash; but it isn't the only door in. I also offer Reiki &mdash; a gentle, hands-light hour of energy work, separate from therapy and honestly explained &mdash; and a small annual retreat is on the way.
        </p>
      </div>
      <a href="/reiki.html" class="btn btn-outline">Learn about Reiki</a>
    </div>
  </section>

  <!-- Approach / Philosophy Section - The Grimoire -->
  <section class="section section-lg bg-blush approach-section grimoire-section">
    <div class="container">
      <div class="approach-content">
        <div class="approach-text reveal-left">
          <p class="eyebrow">My Approach</p>
          <h2>Narrative therapy starts with your story</h2>
          <!-- Decorative vine divider -->
          <div class="vine-divider">
            <VineDivider />
          </div>
          <p>
            Therapy is for everyone. We all have concerns, questions, and troubles &mdash; difficult or confusing times. In my practice, you'll be received with warmth, kindness, and genuine concern.
          </p>
          <p>
            No one knows your life better than you do. My role isn't to diagnose or fix, but to walk alongside you with curiosity and care. Narrative therapy helps us examine the stories you've been told, the ones you tell yourself, and the ones that haven't yet found voice.
          </p>
          <p>
            Together, we'll separate you from the problem, discover the values that guide you, and uncover the "sparkling moments" that point toward your preferred way of living.
          </p>

          <div class="values-list magical-values">
            <!-- Collaborative - Crescent Moon -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconCrescentMoon />
              </div>
              <div class="value-content">
                <h4>Collaborative</h4>
                <p>We work together as partners. You set the direction; I offer reflection and support.</p>
              </div>
            </div>

            <!-- Respectful - Star -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconStar />
              </div>
              <div class="value-content">
                <h4>Respectful & Non-Pathologizing</h4>
                <p>Problems are problems; you are not the problem. We work with struggles, not labels.</p>
              </div>
            </div>

            <!-- Culturally Aware - Sun -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconSun />
              </div>
              <div class="value-content">
                <h4>Culturally Aware</h4>
                <p>I honor the cultural, social, and personal contexts that shape your experience.</p>
              </div>
            </div>

            <!-- Practical - Crystal -->
            <div class="value-item">
              <div class="value-icon magical-icon">
                <IconCrystal />
              </div>
              <div class="value-content">
                <h4>Practical & Reflective</h4>
                <p>We balance deep reflection with real-world strategies you can use today.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Botanical framed image area -->
        <div class="approach-image botanical-frame reveal-right">
          <div class="botanical-frame-border">
            <FrameCornerTL class="frame-corner frame-tl" />
            <FrameCornerTR class="frame-corner frame-tr" />
            <FrameCornerBL class="frame-corner frame-bl" />
            <FrameCornerBR class="frame-corner frame-br" />
          </div>
          <img src="/images/headshot.jpg" alt="Elizabeth - Therapist headshot" class="approach-headshot">
        </div>
      </div>
    </div>
  </section>

  <!-- Sacred Promises - Book Spread -->
  <section class="promises-section">
    <div class="promises-book">
      <!-- Book spine decoration -->
      <div class="book-spine">
        <BookSpine />
      </div>

      <div class="promises-pages">
        <div class="promises-page promises-page-left">
          <div class="page-header">
            <h2 class="page-script">Sacred Promises</h2>
            <div class="page-divider">
              <PageDivider />
            </div>
          </div>

          <div class="promise-list">
            <!-- Promise 1 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconShield />
              </div>
              <div class="promise-content">
                <h4>No Judgment</h4>
                <p>I will NOT judge you. This is a sanctuary free from criticism.</p>
              </div>
            </div>

            <!-- Promise 2 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconHeart />
              </div>
              <div class="promise-content">
                <h4>Unconditional Respect</h4>
                <p>I will RESPECT and HONOR your thoughts, feelings, opinions, and ideas unconditionally.</p>
              </div>
            </div>

            <!-- Promise 3 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconCrown />
              </div>
              <div class="promise-content">
                <h4>You Are The Expert</h4>
                <p>I will not tell you what to do. I believe you are the EXPERT on your own life.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="promises-page promises-page-right">
          <div class="promise-list">
            <!-- Promise 4 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconSeedling />
              </div>
              <div class="promise-content">
                <h4>Facilitator of Growth</h4>
                <p>I will guide you as you explore what you VALUE&mdash;and how to approach your life in ways that reflect those values.</p>
              </div>
            </div>

            <!-- Promise 5 -->
            <div class="promise-item">
              <div class="promise-icon">
                <IconCompass />
              </div>
              <div class="promise-content">
                <h4>Your Journey</h4>
                <p>Therapy is all about YOU. I will be open, honest, genuine, and sincere&mdash;still, therapy is about YOUR journey.</p>
              </div>
            </div>
          </div>

          <!-- Decorative page element -->
          <div class="page-botanical">
            <PageBotanical />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Root System: Hidden Strength Section -->
  <section class="roots-section">
    <div class="container">
      <div class="roots-content">
        <div class="roots-text">
          <p class="roots-eyebrow">Your Hidden Strength</p>
          <h2 class="roots-title">No problem is bigger than your strength</h2>
          <p class="roots-description">Beneath every struggle lies a root system of resilience you may have forgotten. We will work collaboratively as I guide you&mdash;exploring what troubles you and how problems influence your life, decisions, and relationships.</p>
          <p class="roots-closing">I will support you as we work together to find relief from whatever weighs on you, so you may live a lighter, brighter, and more joyful life.</p>
        </div>

        <div class="roots-illustration">
          <figure class="roots-figure">
            <img
              src="/images/therapy-roots.jpg"
              alt="Elizabeth Armstrong seated in a garden"
              class="roots-photo-img"
            />
            <RootsSystem rootsOnly class="roots-svg" aria-hidden="true" />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas of Support Section - Apothecary Cabinet -->
  <section class="section bg-paper apothecary-section">
    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">Areas of Support</p>
        <h2>What brings people to therapy</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
        <p class="lead container-text mx-auto">
          Life presents us with challenges that can feel overwhelming. Here are some of the themes I commonly work with, though your experience is always unique.
        </p>
      </div>

      <div class="apothecary-grid">
        <!-- Anxiety - Fluttering Moth -->
        <div class="apothecary-item reveal stagger-1">
          <div class="apothecary-icon">
            <Moth />
          </div>
          <h4>Anxiety</h4>
          <p>When worry becomes the loudest voice in the room</p>
        </div>

        <!-- Depression - Drooping Flower -->
        <div class="apothecary-item reveal stagger-2">
          <div class="apothecary-icon">
            <DroopingFlower />
          </div>
          <h4>Depression</h4>
          <p>When life feels heavy, gray, or far away</p>
        </div>

        <!-- Life Transitions - Butterfly Emerging -->
        <div class="apothecary-item reveal stagger-3">
          <div class="apothecary-icon">
            <Butterfly />
          </div>
          <h4>Life Transitions</h4>
          <p>Navigating change with clarity and intention</p>
        </div>

        <!-- Relationship Issues - Two Flowers Turned Away -->
        <div class="apothecary-item reveal stagger-4">
          <div class="apothecary-icon">
            <TwoFlowers />
          </div>
          <h4>Relationship Issues</h4>
          <p>Finding new patterns in how you connect</p>
        </div>

        <!-- Trauma - Kintsugi Bowl -->
        <div class="apothecary-item reveal stagger-5">
          <div class="apothecary-icon">
            <KintsugiBowl />
          </div>
          <h4>Trauma</h4>
          <p>When the past still echoes in the present</p>
        </div>

        <!-- Grief & Loss - Willow Branch -->
        <div class="apothecary-item reveal stagger-6">
          <div class="apothecary-icon">
            <WillowBranch />
          </div>
          <h4>Grief & Loss</h4>
          <p>Making space for what you've loved and lost</p>
        </div>

        <!-- LGBTQ+ - Spectrum Arc with Botanical -->
        <div class="apothecary-item reveal stagger-7">
          <div class="apothecary-icon">
            <SpectrumArc />
          </div>
          <h4>LGBTQ+</h4>
          <p>An affirming space for all identities and journeys</p>
        </div>

        <!-- Self-Esteem - Seedling Reaching Light -->
        <div class="apothecary-item reveal stagger-8">
          <div class="apothecary-icon">
            <Seedling />
          </div>
          <h4>Self-Esteem</h4>
          <p>Rediscovering the worth that was always there</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Illuminated Manuscript Quote Section -->
  <section class="illuminated-section">
    <div class="illuminated-page">
      <!-- Decorative corner flourishes -->
      <ManuscriptCornerTL class="manuscript-corner manuscript-corner-tl" />
      <ManuscriptCornerTR class="manuscript-corner manuscript-corner-tr" />
      <ManuscriptCornerBL class="manuscript-corner manuscript-corner-bl" />
      <ManuscriptCornerBR class="manuscript-corner manuscript-corner-br" />

      <div class="illuminated-content">
        <!-- Decorative initial letter -->
        <div class="illuminated-initial" aria-hidden="true">
          <span class="initial-letter">D</span>
          <InitialFlourish class="initial-flourish" />
        </div>

        <blockquote class="illuminated-quote">
          <p><span class="quote-hidden-initial">D</span>on't surrender all your joy for an idea you used to have about yourself that isn't true anymore.</p>
          <footer class="quote-attribution">
            <span class="attribution-dash">—</span>
            <cite>Cheryl Strayed</cite>
          </footer>
        </blockquote>
      </div>

      <!-- Decorative botanical margin illustration -->
      <div class="manuscript-margin">
        <ManuscriptMargin />
      </div>
    </div>
  </section>

  <!-- Constellation Map: Guiding Stars -->
  <section class="constellation-section">
    <div class="constellation-sky">
      <!-- Background stars -->
      <div class="star-field">
        <span class="tiny-star" style="--star-top: 10%; --star-left: 15%;"></span>
        <span class="tiny-star" style="--star-top: 25%; --star-left: 8%;"></span>
        <span class="tiny-star" style="--star-top: 40%; --star-left: 22%;"></span>
        <span class="tiny-star" style="--star-top: 15%; --star-left: 85%;"></span>
        <span class="tiny-star" style="--star-top: 35%; --star-left: 92%;"></span>
        <span class="tiny-star" style="--star-top: 55%; --star-left: 78%;"></span>
        <span class="tiny-star" style="--star-top: 70%; --star-left: 12%;"></span>
        <span class="tiny-star" style="--star-top: 80%; --star-left: 88%;"></span>
        <span class="tiny-star" style="--star-top: 60%; --star-left: 5%;"></span>
        <span class="tiny-star" style="--star-top: 45%; --star-left: 95%;"></span>
      </div>

      <div class="container">
        <div class="constellation-header">
          <p class="constellation-eyebrow">Guiding Stars</p>
          <h2 class="constellation-title">What we navigate toward</h2>
          <p class="constellation-subtitle">Struggles may bring you in, but they don't get to steer. These are some of the stars people set their course by &mdash; we'll find the ones that are yours.</p>
        </div>

        <div class="constellation-map">
          <svg class="constellation-lines" viewBox="0 0 900 500">
            <!-- Lines generated dynamically by JavaScript -->
          </svg>

          <div class="constellation-stars">
            <!-- Star 1: Clarity -->
            <div class="constellation-star" style="--star-top: 15%; --star-left: 15%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Clarity</span>
            </div>

            <!-- Star 2: Self-Trust -->
            <div class="constellation-star" style="--star-top: 28%; --star-left: 38%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Self-Trust</span>
            </div>

            <!-- Star 3: Connection -->
            <div class="constellation-star" style="--star-top: 18%; --star-left: 58%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Connection</span>
            </div>

            <!-- Star 4: Courage -->
            <div class="constellation-star" style="--star-top: 22%; --star-left: 80%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Courage</span>
            </div>

            <!-- Star 5: Rest -->
            <div class="constellation-star" style="--star-top: 50%; --star-left: 22%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Rest</span>
            </div>

            <!-- Star 6: Belonging -->
            <div class="constellation-star" style="--star-top: 65%; --star-left: 42%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Belonging</span>
            </div>

            <!-- Star 7: Growth -->
            <div class="constellation-star" style="--star-top: 58%; --star-left: 63%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Growth</span>
            </div>

            <!-- Star 8: Joy -->
            <div class="constellation-star" style="--star-top: 75%; --star-left: 78%;">
              <div class="star-glow"></div>
              <ConstellationStar class="star-icon" />
              <span class="star-label">Joy</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section - Moon Phases Journey -->
  <section class="section bg-sand moon-journey-section">
    <!-- Decorative botanical vine divider - top (CSS background pattern) -->
    <div class="vine-divider vine-divider-top"></div>

    <!-- Decorative botanical vine divider - bottom (CSS background pattern) -->
    <div class="vine-divider vine-divider-bottom"></div>

    <div class="container">
      <div class="text-center mb-12">
        <p class="eyebrow">How It Works</p>
        <h2>Starting therapy is simple</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
      </div>

      <div class="moon-steps-grid">
        <!-- Connecting vine path -->
        <div class="moon-path">
          <MoonPath />
        </div>

        <div class="moon-step reveal stagger-1">
          <!-- New Moon -->
          <div class="moon-icon">
            <NewMoon />
          </div>
          <h3>Free Consultation</h3>
          <p class="moon-phase-label">New Moon</p>
          <p>We'll have a brief call to discuss what brings you to therapy and answer any questions. This helps us both determine if we're a good fit.</p>
        </div>

        <div class="moon-step reveal stagger-2">
          <!-- Half Moon -->
          <div class="moon-icon">
            <WaxingMoon />
          </div>
          <h3>First Session</h3>
          <p class="moon-phase-label">Waxing Moon</p>
          <p>In our first meeting, we'll explore your story more deeply. I'll get to know you and what matters most. You'll get a sense of how we work together.</p>
        </div>

        <div class="moon-step reveal stagger-3">
          <!-- Full Moon -->
          <div class="moon-icon">
            <FullMoon />
          </div>
          <h3>Ongoing Work</h3>
          <p class="moon-phase-label">Full Moon</p>
          <p>We'll meet regularly (typically weekly) to continue our exploration. Each session builds on the last, moving at a pace that feels right for you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Clients Tell Me Section - Journal Pages -->
  <section class="section bg-paper testimonial-section journal-section">
    <div class="container">
      <div class="text-center mb-10">
        <p class="eyebrow">What Clients Often Tell Me</p>
        <h2>When people reach out, they often share thoughts like these...</h2>
        <div class="decorative-divider">
          <LeafDivider />
        </div>
      </div>

      <div class="journal-pages">
        <div class="journal-page reveal stagger-1" style="--rotation: -2deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to feel like myself again, but I'm not even sure who that is anymore.</p>
        </div>

        <div class="journal-page reveal stagger-2" style="--rotation: 1.5deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I know what I should do, but I can't seem to make it happen.</p>
        </div>

        <div class="journal-page reveal stagger-3" style="--rotation: -1deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to stop having the same argument over and over with my partner.</p>
        </div>

        <div class="journal-page reveal stagger-4" style="--rotation: 2deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I need a space where I don't have to perform or pretend everything is fine.</p>
        </div>

        <div class="journal-page reveal stagger-5" style="--rotation: -1.5deg;">
          <div class="journal-quote-mark">
            <QuoteMark />
          </div>
          <p class="journal-text">I want to understand why I keep getting in my own way.</p>
        </div>
      </div>

      <p class="journal-closing">
        If any of these resonate, you're in the right place.
      </p>
    </div>
  </section>

  <!-- Garden Gate: Final CTA -->
  <section class="garden-gate-section">
    <div class="gate-frame">
      <GardenGate class="gate-svg" />

      <div class="gate-content">
