---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Fees & Insurance | Elizabeth Armstrong Therapy" description="Therapy fees, insurance information, and payment options at Elizabeth Armstrong Therapy. Transparent pricing for individual, couples, and family therapy.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Investment</p>
      <h1>Fees & Insurance</h1>
      <p class="lead">
        Transparent pricing and payment options to make therapy accessible.
      </p>
    </div>
  </section>

  <!-- Fees Content -->
  <section class="section bg-paper">
    <div class="container container-narrow">
      <h2 class="text-center">Coming Soon</h2>
      <div class="decorative-line center"></div>
      <p class="text-center">
        This page is currently being developed. Check back soon for detailed information about session fees, insurance options, and payment methods.
      </p>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band">
    <div class="container">
      <h2>Questions about fees?</h2>
      <p>
        I'm happy to discuss fees and payment options during our free 15-minute consultation.
      </p>
      <a href="/contact.html" class="btn btn-primary btn-lg">Schedule Your Free Consultation</a>
    </div>
  </section>

</BaseLayout>
