---
import { withBase } from "@/lib/withBase";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  IconCollaborative,
  IconSeedling,
  IconCompass,
  IconGraduation,
  IconLicense,
  IconTraining,
  IconHeart,
} from "@illustrations/icons";
import { HerbSprig, LavenderSprig, Wildflower, LeafBranch } from "@illustrations/botanicals";
import { QuoteMark, Clothespin } from "@illustrations/misc";
import "@styles/pages/about.css";
---

<BaseLayout
  title="About | Growing Brighter Therapy — Elizabeth Armstrong, LMFT"
  description="Meet Elizabeth Armstrong, MA, LMFT — a narrative therapist in Orange County and former teacher who came to this work at 37. Warm, collaborative therapy for women navigating life's big transitions."
>
  <!-- 1. Board Hero: the vision board -->
  <section class="board-hero">
    <div class="board-frame">
      <div class="board-surface">
        <!-- Title card -->
        <div class="board-item bi-title" style="--delay: 0.1s;">
          <div class="board-item-inner" style="--tilt: -2deg;">
            <div class="board-title-card">
              <span class="board-pin pin-rose" aria-hidden="true"></span>
              <p class="eyebrow">About Me</p>
              <h1>Hello, I'm Elizabeth</h1>
              <p class="board-lead">
                I'm a narrative therapist in Orange County, and a former teacher who found this work
                at 37. I believe you are the expert on your own life — my job is to listen.
              </p>
            </div>
          </div>
        </div>

        <!-- Fence photo -->
        <div class="board-item bi-fence" style="--delay: 0.25s;">
          <div class="board-item-inner" style="--tilt: 4deg;">
            <figure class="polaroid">
              <span class="board-pin pin-clay" aria-hidden="true"></span>
              <img
                src={withBase("/images/about-hero-fence.jpg")}
                alt="Elizabeth in a wide-brimmed hat, looking down and smiling near a wooden fence"
                width="1600"
                height="1066"
              />
              <figcaption class="polaroid-caption">slow mornings</figcaption>
            </figure>
          </div>
        </div>

        <!-- Couch photo -->
        <div class="board-item bi-couch" style="--delay: 0.4s;">
          <div class="board-item-inner" style="--tilt: -5deg;">
            <figure class="polaroid">
              <span class="washi-tape washi-top" aria-hidden="true"></span>
              <img
                src={withBase("/images/about-hero-couch.jpg")}
                alt="Elizabeth seated on a couch in warm lamplight, relaxed and smiling"
                width="1066"
                height="1600"
              />
              <figcaption class="polaroid-caption">at home in the heart</figcaption>
            </figure>
          </div>
        </div>

        <!-- Script word cutouts -->
        <div class="board-item bi-word-1" style="--delay: 0.55s;">
          <div class="board-item-inner" style="--tilt: -6deg;">
            <span class="word-cutout"
              ><span class="board-pin pin-sage" aria-hidden="true"></span>warmth</span
            >
          </div>
        </div>
        <div class="board-item bi-word-2" style="--delay: 0.65s;">
          <div class="board-item-inner" style="--tilt: 3deg;">
            <span class="word-cutout"
              ><span class="washi-tape washi-corner washi-sage" aria-hidden="true"
              ></span>connection</span
            >
          </div>
        </div>
        <div class="board-item bi-word-3" style="--delay: 0.75s;">
          <div class="board-item-inner" style="--tilt: -3deg;">
            <span class="word-cutout"
              ><span class="board-pin pin-peach" aria-hidden="true"></span>kindness</span
            >
          </div>
        </div>

        <!-- Quote scrap -->
        <div class="board-item bi-quote" style="--delay: 0.85s;">
          <div class="board-item-inner" style="--tilt: 2deg;">
            <p class="quote-scrap">
              <span class="washi-tape washi-top washi-sage" aria-hidden="true"></span>"no problem is
              bigger than your strength"
            </p>
          </div>
        </div>

        <!-- Botanical sprigs -->
        <div class="board-item bi-sprig-1" aria-hidden="true" style="--delay: 0.3s;">
          <div class="board-item-inner" style="--tilt: -15deg;">
            <HerbSprig class="board-sprig" />
          </div>
        </div>
        <div class="board-item bi-sprig-2" aria-hidden="true" style="--delay: 0.5s;">
          <div class="board-item-inner" style="--tilt: 12deg;">
            <LavenderSprig class="board-sprig" />
          </div>
        </div>
        <div class="board-item bi-sprig-3" aria-hidden="true" style="--delay: 0.7s;">
          <div class="board-item-inner" style="--tilt: -8deg;">
            <Wildflower class="board-sprig" />
          </div>
        </div>

        <!-- Loose washi + a spare pin for texture -->
        <div class="board-item bi-pin-spare" aria-hidden="true" style="--delay: 1.1s;">
          <span class="board-pin pin-sage"></span>
        </div>
        <div class="board-item bi-washi-1" aria-hidden="true" style="--delay: 0.9s;">
          <div class="board-item-inner">
            <span class="washi-tape" style="--tape-rot: -22deg; position: static; display: block;"
            ></span>
          </div>
        </div>
        <div class="board-item bi-washi-2" aria-hidden="true" style="--delay: 1s;">
          <div class="board-item-inner">
            <span
              class="washi-tape washi-sage"
              style="--tape-rot: 14deg; position: static; display: block;"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Pinned Letter: My Story -->
  <section class="section bg-paper">
    <div class="container">
      <div class="pinned-letter-grid">
        <div class="pinned-card reveal-left">
          <div class="pinned-card-inner paper-card letter-sheet" style="--tilt: -1deg;">
            <span class="board-pin pin-sage pin-corner-left" aria-hidden="true"></span>
            <span class="board-pin pin-clay pin-corner-right" aria-hidden="true"></span>
            <h2>From the classroom to the therapy room</h2>
            <p>
              For years, I taught young children — including a stretch at Head Start, a program so
              warm and whole-family that its spirit never left me. But my favorite moments weren't
              in the classroom. They were the one-on-one conversations with parents at pickup, in
              that quiet space where they finally felt seen.
            </p>
            <p>
              It eventually clicked: maybe therapy was where I was really meant to be. So I went to
              grad school at 37, training nights and weekends while I was still teaching full-time.
              And when I found narrative therapy, I just knew I had landed in the right place. These
              were my people.
            </p>
            <p>
              I've been licensed since 2019, and these days I also serve as a clinical supervisor,
              mentoring new therapists at the institute where I trained. Having reinvented my own
              life right around midlife, I find there's a particular kind of joy in companioning
              someone through a season of change.
            </p>
            <div class="letter-quote">
              <span class="washi-tape washi-top" aria-hidden="true"></span>
              <p>
                "I will not tell you what to do. I view problems as separate from people — and my
                work is simply to make room while you do yours."
              </p>
            </div>
          </div>
        </div>

        <div class="story-polaroid-wrap reveal-right">
          <figure class="polaroid story-polaroid" style="--tilt: 3deg;">
            <span class="washi-tape washi-top" aria-hidden="true"></span>
            <img
              src={withBase("/images/about-story-bench.jpg")}
              alt="Elizabeth sitting on a park bench outdoors with a warm smile"
              width="1066"
              height="1600"
              loading="lazy"
              decoding="async"
            />
            <figcaption class="polaroid-caption">come say hi</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Session Cards: Working Together -->
  <section class="section bg-blush">
    <div class="container">
      <p class="eyebrow text-center">Working Together</p>
      <h2 class="text-center">What to expect when we sit down</h2>

      <div class="session-notes pinned-card reveal">
        <div class="pinned-card-inner paper-card session-notes-inner" style="--tilt: -0.5deg;">
          <span class="board-pin pin-rose pin-corner-left" aria-hidden="true"></span>
          <span class="board-pin pin-sage pin-corner-right" aria-hidden="true"></span>
          <p>
            Even in a collaborative relationship, I think of myself as the host of this gathering —
            the one who tends the trust, the safety, and the openness. So you'll be received with
            warmth, kindness, and genuine concern. I won't rush you, and I won't judge you. Come as
            you are.
          </p>
          <p>
            Our sessions are mostly conversation. We might make sense of a big transition, trace a
            pattern that keeps showing up, or slow down and notice what an experience has meant to
            you. I tend to ask a lot of questions — not to test you, but because I'm honestly
            curious about your life.
          </p>
          <p>
            I work from a feminist, strengths-based lens, and I'll sometimes send you home with a
            reading or a small practice to carry between visits. I'm not here to fix you or heal
            you. I'm here to hold the space while you heal yourself — I believe, deeply, that you
            already have what you need.
          </p>
          <p>
            Above all, you'll be met as a whole person, not a list of symptoms. I'm just as
            interested in your strengths, your values, and the life you're hoping to build as I am
            in whatever weighs on you right now. We'll work with all of it, together.
          </p>
        </div>
      </div>

      <div class="index-cards-grid">
        <div class="pinned-card reveal stagger-1">
          <div class="pinned-card-inner paper-card index-card-inner" style="--tilt: -2deg;">
            <span class="board-pin pin-sage" aria-hidden="true"></span>
            <IconCollaborative aria-hidden="true" />
            <h4>Collaborative</h4>
            <p>
              We're partners in this. I bring my training and a curious presence; you bring lived
              experience and real wisdom about your own life.
            </p>
          </div>
        </div>
        <div class="pinned-card reveal stagger-2">
          <div class="pinned-card-inner paper-card index-card-inner" style="--tilt: 1.5deg;">
            <span class="board-pin pin-clay" aria-hidden="true"></span>
            <IconSeedling aria-hidden="true" />
            <h4>Strengths-based</h4>
            <p>
              Let's harvest your strengths and capabilities. I start from what's already working in
              you, not from what's broken — there's more there than you think.
            </p>
          </div>
        </div>
        <div class="pinned-card reveal stagger-3">
          <div class="pinned-card-inner paper-card index-card-inner" style="--tilt: -1deg;">
            <span class="board-pin pin-rose" aria-hidden="true"></span>
            <IconCompass aria-hidden="true" />
            <h4>Curious</h4>
            <p>
              I ask, listen, and look at things from fresh angles with you — the questions matter
              more than any answers I could hand you.
            </p>
          </div>
        </div>
      </div>

      <div class="draw-from pinned-card reveal">
        <div class="pinned-card-inner paper-card draw-from-inner" style="--tilt: 0.5deg;">
          <span class="board-pin pin-peach" aria-hidden="true"></span>
          <h4>What I draw from</h4>
          <p>
            My home base is <strong>narrative therapy</strong>, which honors the stories we tell
            about ourselves and the bigger cultural and social forces that shape them. We are
            multistoried — and we get to keep writing. I weave in <strong>mindfulness</strong> and person-centered
            warmth, all through a feminist lens. Beyond the office, I also offer <a
              href={withBase("/index.html#services")}><strong>walk-and-talk sessions</strong></a
            > along the ocean and &mdash; separate from therapy &mdash; <a
              href={withBase("/reiki.html")}><strong>Reiki</strong></a
            > and an annual retreat, for those drawn to something more embodied.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Photo Band: golden quote -->
  <section class="photo-band">
    <img
      class="photo-band-img"
      src={withBase("/images/about-band-eucalyptus.jpg")}
      alt=""
      width="2000"
      height="1333"
      loading="lazy"
      decoding="async"
    />
    <div class="photo-band-content reveal">
      <span class="photo-band-quotemark" aria-hidden="true"><QuoteMark /></span>
      <p class="band-quote">toward a lighter, brighter, more joyful life</p>
      <p class="band-attribution">Elizabeth Armstrong, MA, LMFT</p>
    </div>
  </section>

  <!-- 5. Pinned Certs: Credentials -->
  <section class="section bg-sand">
    <div class="container">
      <p class="eyebrow text-center">Education &amp; Training</p>
      <h2 class="text-center">Credentials</h2>

      <div class="certs-grid">
        <div class="pinned-card reveal-scale stagger-1">
          <div class="pinned-card-inner paper-card cert-card-inner" style="--tilt: -1.5deg;">
            <span class="board-pin pin-sage" aria-hidden="true"></span>
            <div class="cert-seal"><IconGraduation aria-hidden="true" /></div>
            <h4>MA, Clinical Psychology · BS, Family Service</h4>
            <p>Pepperdine University, 2016</p>
          </div>
        </div>
        <div class="pinned-card reveal-scale stagger-2">
          <div class="pinned-card-inner paper-card cert-card-inner" style="--tilt: 1deg;">
            <span class="board-pin pin-clay" aria-hidden="true"></span>
            <div class="cert-seal"><IconLicense aria-hidden="true" /></div>
            <h4>Licensed Marriage &amp; Family Therapist (LMFT)</h4>
            <p>California Board of Behavioral Sciences, License #111154 · since 2019</p>
          </div>
        </div>
        <div class="pinned-card reveal-scale stagger-3">
          <div class="pinned-card-inner paper-card cert-card-inner" style="--tilt: 1deg;">
            <span class="board-pin pin-rose" aria-hidden="true"></span>
            <div class="cert-seal"><IconTraining aria-hidden="true" /></div>
            <h4>AAMFT-Certified · Clinical Supervisor</h4>
            <p>
              Substance Misuse and LGBTQIA Affirmative Therapy; supervisor at California Family
              Institute
            </p>
          </div>
        </div>
        <div class="pinned-card reveal-scale stagger-4">
          <div class="pinned-card-inner paper-card cert-card-inner" style="--tilt: -1deg;">
            <span class="board-pin pin-peach" aria-hidden="true"></span>
            <div class="cert-seal"><IconHeart aria-hidden="true" /></div>
            <h4>Reiki Master · Certified Pet Grief Counselor</h4>
            <p>
              Certified in Reiki since 2020, a Reiki Master since 2021; trained to companion you
              through pet loss
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Twine Gallery: Off the Clock -->
  <section class="section bg-paper">
    <div class="container">
      <h2 class="text-center">A little more about me</h2>
      <div class="decorative-line center"></div>

      <div class="twine-gallery-intro">
        <p>
          I connect to my joyful spirit through travel, live music, yoga, and time with my friends,
          family, and puppies — three of them, to be exact. There's Leonard Sprinkles, my big goofy
          greyhound; Meatie, the dachshund comedian and snuggle muffin; and Otis, the dachshund we
          rescued in 2025, who made our home complete.
        </p>
        <p>
          I'm a longtime yogi, a lover of woo-woo things, and a maker of vision boards. Every New
          Year I choose a word to grow toward — peace, release, joy. In 2025 it was warmth, and
          honestly? I think I've arrived.
        </p>
      </div>

      <div class="twine-wrap">
        <div class="twine-line" aria-hidden="true"></div>
        <div class="twine-photos">
          <div class="hung-photo reveal stagger-1">
            <figure class="polaroid" style="--tilt: -3deg; --sway-delay: 0s;">
              <span class="clothespin" aria-hidden="true"><Clothespin /></span>
              <img
                src={withBase("/images/about-dogs-greyhound.jpg")}
                alt="Elizabeth at home on the rug with Leonard Sprinkles, Meatie, and Otis — her greyhound and two dachshunds"
                width="1066"
                height="1600"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="polaroid-caption">the whole pack</figcaption>
            </figure>
          </div>
          <div class="hung-photo reveal stagger-2">
            <figure class="polaroid photo-warmed" style="--tilt: 4deg; --sway-delay: 2.2s;">
              <span class="clothespin" aria-hidden="true"><Clothespin /></span>
              <img
                src={withBase("/images/about-dogs-couch.jpg")}
                alt="Elizabeth laughing on the couch while hugging a dachshund"
                width="1066"
                height="1600"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="polaroid-caption">my favorite days</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Pinned CTA: a note, not a pitch -->
  <section class="section bg-blush">
    <div class="container">
      <div class="cta-note-wrap pinned-card reveal-scale">
        <div class="pinned-card-inner paper-card cta-note-inner" style="--tilt: -1deg;">
          <span class="board-pin pin-rose" aria-hidden="true"></span>
          <h2>Let's see if we're a good fit</h2>
          <p>
            I offer a free 15-minute consultation — a chance to talk about what you're looking for
            and whether I might be the right person to walk alongside you for a while. It would be a
            privilege to be invited into your story.
          </p>
          <a href={withBase("/contact.html")} class="btn btn-primary btn-lg"
            >Schedule Your Free Consultation</a
          >
          <span class="cta-signature">&mdash; Elizabeth</span>
        </div>
        <span class="cta-sprig" aria-hidden="true"><LeafBranch /></span>
      </div>
    </div>
  </section>
</BaseLayout>
